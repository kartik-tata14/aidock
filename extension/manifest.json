{
  "manifest_version": 3,
  "name": "AIDock — Save AI Tools",
  "version": "1.0.0",
  "description": "Quickly save any AI tool to your AIDock dashboard from any webpage.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.svg"
  },
  "icons": {
    "16": "icons/icon128.svg",
    "48": "icons/icon128.svg",
    "128": "icons/icon128.svg"
  }
}
